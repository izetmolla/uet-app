{
  "expo": {
    "name": "Uet APP",
    "slug": "uetapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.izetmolla.uetapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.izetmolla.uetapp",
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME) needs access to your Camera to capture photos and videos.",
        "NSMicrophoneUsageDescription": "$(PRODUCT_NAME) needs access to your Microphone to record audio for video recordings.",
      }
    },
    "android": {
      "permissions": ["android.permission.CAMERA", "android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#2e4d88",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.izetmolla.uetapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2e4d88",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#05070f"
          },
          "android": {
            "image": "./assets/images/splash.png",
            "imageWidth": 76
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "We need camera access so you can scan documents.",
          "recordAudioAndroid": false
        }
      ],
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "We need camera access so you can scan documents."
        }
      ],
      "expo-web-browser",
      "expo-video",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "253d7fa7-5a22-4891-a11d-6517138beda4"
      }
    },
    "owner": "uet.edu.al"
  }
}
